# Supabase — get from project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Twilio — stubbed in v1, wire in v2
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email — Resend (resend.com)
RESEND_API_KEY=
# REQUIRED for outbound email: a sender on a domain verified in Resend
# (Resend dashboard → Domains). Format: Vigilight <noreply@getvigilight.com>
# If unset, sends use an invalid placeholder domain and fail visibly.
RESEND_FROM_EMAIL=

# Notifications cron — set to a random secret string, send as X-Cron-Secret header
CRON_SECRET=

# Sentry Crons — dead-man monitor slug for the daily overdue SMS cron.
# The monitor is auto-created in Sentry on the cron's first check-in (config lives
# in app/api/notifications/overdue/route.ts); it can also be created/tuned manually
# in the Sentry dashboard under Crons — keep the slug in sync either way.
SENTRY_CRON_MONITOR_SLUG=overdue-sms-cron

# Meeting Recording — Deepgram (deepgram.com)
DEEPGRAM_API_KEY=

# AI Extraction — Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
